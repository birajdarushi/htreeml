# Dependencies
node_modules/
package-lock.json

# Logs
*.log
npm-debug.log*

# Snapshot files are created at runtime — ignore contents but keep the folder
server/snapshots/*
!server/snapshots/.gitkeep

# Index output files are generated by the indexer — ignore contents
server/index-output/
