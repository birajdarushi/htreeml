{
  "name": "htreeml-mutation-analyzer",
  "version": "1.0.0",
  "description": "DOM mutation analysis tool for HTML snapshots",
  "main": "analyze_mutations.js",
  "scripts": {
    "analyze": "node analyze_mutations.js",
    "build": "esbuild extension/src/content/index.js --bundle --outfile=extension/content.js",
    "start": "node server/src/index.js",
    "index": "node --max-old-space-size=4096 server/scripts/indexer.js",
    "index:force": "node --max-old-space-size=4096 server/scripts/indexer.js --force",
    "test:dropdown": "node server/scripts/test-dropdown-indexer.js",
    "ai:context": "node server/scripts/generate-ai-context.js"
  },
  "dependencies": {
    "jsdom": "^23.0.1"
  },
  "keywords": [
    "dom",
    "mutation",
    "html",
    "analysis"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
